<Window x:Class="Summarizer.App.AppSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="680"
        Height="600"
        MinWidth="500"
        MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <DockPanel Background="{DynamicResource AppBackground}">

        <!-- 상단: JSON 파일로 열기 -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Button Content="JSON 파일로 열기"
                    Command="{Binding OpenJsonFileCommand}"
                    HorizontalAlignment="Left"
                    Padding="8,4" />
        </Border>

        <!-- 하단: 닫기 버튼 -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,8">
            <Button Content="닫기"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"
                    Width="80"
                    Height="28" />
        </Border>

        <!-- 중앙: 설정 편집 영역 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">

                <!-- 예약 확인 텍스트 -->
                <Label Content="예약 확인 텍스트" Padding="0,0,0,4" />
                <TextBox Text="{Binding ReservationConfirmMessage, UpdateSourceTrigger=LostFocus}"
                         Margin="0,0,0,12" />

                <Separator Margin="0,0,0,12" />

                <!-- 생년월일 표준화 -->
                <CheckBox Content="생년월일 표준화 사용"
                          IsChecked="{Binding NormalizeBirthNumber}"
                          Margin="0,0,0,12" />

                <Separator Margin="0,0,0,12" />

                <!-- 상담 메시지 형식 (formMessages) -->
                <Label Content="상담 메시지 형식" Padding="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="추가"     Command="{Binding AddFormMessageCommand}"         Padding="8,3" Margin="0,0,4,0" />
                    <Button Content="삭제"     Command="{Binding DeleteFormMessagesCommand}"     Padding="8,3" Margin="0,0,4,0" />
                    <Button Content="위로"     Command="{Binding MoveFormMessageUpCommand}"      Padding="8,3" Margin="0,0,4,0" />
                    <Button Content="아래로"   Command="{Binding MoveFormMessageDownCommand}"    Padding="8,3" Margin="0,0,4,0" />
                    <Button Content="모두선택" Command="{Binding SelectAllFormMessagesCommand}"  Padding="8,3" />
                </StackPanel>
                <ItemsControl ItemsSource="{Binding FormMessages}" Margin="0,0,0,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,2"
                                    Padding="6,4">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0" />
                                    <TextBox Text="{Binding Text, UpdateSourceTrigger=LostFocus}"
                                             Width="440"
                                             VerticalAlignment="Center" />
                                    <CheckBox Content="정규표현식"
                                              IsChecked="{Binding IsRegex}"
                                              VerticalAlignment="Center"
                                              Margin="8,0,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,0,0,12" />

                <!-- 직원 메시지 변환 (replaceStaffMessages) -->
                <Label Content="직원 메시지 변환" Padding="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="추가"     Command="{Binding AddReplaceStaffMessageCommand}"         Padding="8,3" Margin="0,0,4,0" />
                    <Button Content="삭제"     Command="{Binding DeleteReplaceStaffMessagesCommand}"     Padding="8,3" Margin="0,0,4,0" />
                    <Button Content="위로"     Command="{Binding MoveReplaceStaffMessageUpCommand}"      Padding="8,3" Margin="0,0,4,0" />
                    <Button Content="아래로"   Command="{Binding MoveReplaceStaffMessageDownCommand}"    Padding="8,3" Margin="0,0,4,0" />
                    <Button Content="모두선택" Command="{Binding SelectAllReplaceStaffMessagesCommand}"  Padding="8,3" />
                </StackPanel>
                <ItemsControl ItemsSource="{Binding ReplaceStaffMessages}" Margin="0,0,0,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,4"
                                    Padding="6,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Top"
                                              Margin="0,4,8,0" />

                                    <StackPanel Grid.Column="1">

                                        <!-- 메모 행 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Label Content="메모" Width="72" VerticalAlignment="Center" Padding="0" />
                                            <CheckBox Content="추가"
                                                      IsChecked="{Binding HasComment}"
                                                      VerticalAlignment="Center">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasComment}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>
                                            <TextBox Text="{Binding Comment, UpdateSourceTrigger=LostFocus}"
                                                     Width="440"
                                                     VerticalAlignment="Center">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasComment}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>

                                        <!-- 찾을 메시지 행 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Label Content="찾을 메시지" Width="72" VerticalAlignment="Center" Padding="0" />
                                            <TextBox Text="{Binding Pattern, UpdateSourceTrigger=LostFocus}"
                                                     Width="380"
                                                     VerticalAlignment="Center" />
                                            <CheckBox Content="정규표현식"
                                                      IsChecked="{Binding IsPatternRegex}"
                                                      VerticalAlignment="Center"
                                                      Margin="8,0,0,0" />
                                        </StackPanel>

                                        <!-- 바꿀 메시지 행 -->
                                        <StackPanel Orientation="Horizontal">
                                            <Label Content="바꿀 메시지" Width="72" VerticalAlignment="Center" Padding="0" />
                                            <CheckBox Content="추가"
                                                      IsChecked="{Binding HasReplacement}"
                                                      VerticalAlignment="Center">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasReplacement}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>
                                            <TextBox Text="{Binding Replacement, UpdateSourceTrigger=LostFocus}"
                                                     Width="380"
                                                     VerticalAlignment="Center">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasReplacement}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <CheckBox Content="정규표현식"
                                                      IsChecked="{Binding IsReplacementRegex}"
                                                      VerticalAlignment="Center"
                                                      Margin="8,0,0,0">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasReplacement}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>
                                        </StackPanel>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
