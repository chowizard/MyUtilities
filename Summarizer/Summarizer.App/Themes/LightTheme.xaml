<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 색상 팔레트 -->
    <Color x:Key="AppBackgroundColor">#F5F5F5</Color>
    <Color x:Key="PanelBackgroundColor">#FFFFFF</Color>
    <Color x:Key="ControlBackgroundColor">#E8E8E8</Color>
    <Color x:Key="AppForegroundColor">#1E1E1E</Color>
    <Color x:Key="BorderColor">#CCCCCC</Color>
    <Color x:Key="MenuBackgroundColor">#F0F0F0</Color>
    <Color x:Key="DisabledForegroundColor">#888888</Color>

    <!-- 브러시 -->
    <SolidColorBrush x:Key="AppBackground"     Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackground"   Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="ControlBackground" Color="{StaticResource ControlBackgroundColor}" />
    <SolidColorBrush x:Key="AppForeground"     Color="{StaticResource AppForegroundColor}" />
    <SolidColorBrush x:Key="BorderBrush"       Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="MenuBackground"    Color="{StaticResource MenuBackgroundColor}" />
    <SolidColorBrush x:Key="DisabledForeground" Color="{StaticResource DisabledForegroundColor}" />

    <!-- Window -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource AppBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background"   Value="{StaticResource PanelBackground}" />
        <Setter Property="Foreground"   Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"      Value="4" />
        <Setter Property="CaretBrush"   Value="{StaticResource AppForeground}" />
    </Style>

    <!-- Button -->
    <Style TargetType="Button">
        <Setter Property="Background"   Value="{StaticResource ControlBackground}" />
        <Setter Property="Foreground"   Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"      Value="8,4" />
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <!-- Label -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <!-- Menu -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource MenuBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <!-- MenuItem -->
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{StaticResource MenuBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <!-- Separator -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BorderBrush}" />
    </Style>

</ResourceDictionary>
