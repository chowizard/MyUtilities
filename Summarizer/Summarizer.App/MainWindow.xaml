<Window x:Class="Summarizer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Summarizer (v1.2.0)"
        Width="830" Height="460"
        MinWidth="600" MinHeight="380"
        Topmost="{Binding IsAlwaysOnTop}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 입력 영역 -->
        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <Label DockPanel.Dock="Top" Content="변환할 텍스트 입력" Padding="0,0,0,4" />
            <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Malgun Gothic"
                     FontSize="13" />
        </DockPanel>

        <!-- 버튼 영역 -->
        <StackPanel Grid.Column="1"
                    Width="130"
                    VerticalAlignment="Center"
                    Margin="8,0">
            <CheckBox Content="항상 맨 위로 고정"
                      IsChecked="{Binding IsAlwaysOnTop}"
                      Margin="0,0,0,16" />
            <Button Content="변환하기"
                    Command="{Binding ConvertCommand}"
                    Height="33" Margin="0,0,0,8" />
            <Button Content="복사하기"
                    Command="{Binding CopyOutputCommand}"
                    Height="33" Margin="0,0,0,8" />
            <Button Content="비우기"
                    Command="{Binding ClearCommand}"
                    Height="33" />
        </StackPanel>

        <!-- 출력 영역 -->
        <DockPanel Grid.Column="2" Margin="8,0,0,0">
            <Label DockPanel.Dock="Top" Content="변환 결과" Padding="0,0,0,4" />
            <TextBox Text="{Binding OutputText, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Malgun Gothic"
                     FontSize="13" />
        </DockPanel>
    </Grid>
</Window>
